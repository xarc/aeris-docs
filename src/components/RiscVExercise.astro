---
export interface Register {
  name: string;
  alias: string;
}

export interface MemorySegment {
  address: string;
  alias: string;
}

export interface PrefilledRow {
  pc: string;
  instruction: string;
  pseudoInstruction?: string;
  values: string[];
}

interface Props {
  description?: string;
  code?: string;
  registers: Register[];
  memorySegments?: MemorySegment[];
  pseudoInstructionColumn?: boolean;
  initialValues?: string[];
  prefilledRows?: PrefilledRow[];
  correctRows?: PrefilledRow[];
  totalRows?: number;
  lang?: "pt" | "en";
  compact?: boolean;
}

const {
  description,
  code,
  registers,
  memorySegments = [],
  pseudoInstructionColumn = false,
  initialValues,
  prefilledRows = [],
  correctRows = [],
  totalRows = 7,
  lang = "pt",
  compact = false,
} = Astro.props;

const translations = {
  pt: {
    assemblyCode: "Código Assembly",
    fillTable: "Preencha a tabela abaixo",
    before: "Antes",
    after: "Após executar a instrução",
    pseudoInstruction: "Pseudoinstrução",
    addRow: "Adicionar linha",
    check: "Verificar",
    savePDF: "Salvar como PDF",
    pdfNotice:
      "Dica: no diálogo de impressão, selecione o tamanho A2 para melhor resultado.",
  },
  en: {
    assemblyCode: "Assembly Code",
    fillTable: "Fill in the table below",
    before: "Before",
    after: "After executing the instruction",
    pseudoInstruction: "Pseudo-instruction",
    addRow: "Add row",
    check: "Check",
    savePDF: "Save as PDF",
    pdfNotice:
      "Tip: in the print dialog, select A2 paper size for best results.",
  },
};

const labels = translations[lang];
const registerCount = registers.length;
const beforeColspan = pseudoInstructionColumn ? 3 : 2;
const afterColspan = registerCount + memorySegments.length * 2;
const tableClass = compact ? "exec-table compact" : "exec-table";
---

<div class="exercise">
  {description && <p class="exercise-description" set:html={description} />}

  {
    code && (
      <div class="code-wrapper">
        <h3>{labels.assemblyCode}</h3>
        <code class="assembly-code">{code}</code>
      </div>
    )
  }

  <h3>{labels.fillTable}</h3>

  <form class="exercise-form" data-pseudo={pseudoInstructionColumn ? "1" : "0"} data-correct={JSON.stringify(correctRows)}>
    <div class="table-wrapper">
      <table class={tableClass}>
        <thead>
          <tr>
            <th class="col-before" colspan={beforeColspan}>{labels.before}</th>
            <th class="col-after" colspan={afterColspan}>{labels.after}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="col-header">PC</td>
            <td class="col-header">Instruction</td>
            {
              pseudoInstructionColumn && (
                <td class="col-header">{labels.pseudoInstruction}</td>
              )
            }
            {
              registers.map((register) => (
                <td class="col-header">{register.name}</td>
              ))
            }
            {
              memorySegments.map((segment) => (
                <>
                  <td class="col-header">{segment.address}</td>
                  <td class="col-header">...</td>
                </>
              ))
            }
          </tr>
          <tr>
            <td></td>
            <td></td>
            {pseudoInstructionColumn && <td />}
            {
              registers.map((register) => (
                <td class="col-alias">({register.alias})</td>
              ))
            }
            {
              memorySegments.map((segment) => (
                <>
                  <td class="col-alias">{segment.alias}</td>
                  <td />
                </>
              ))
            }
          </tr>
          {
            initialValues && (
              <tr>
                <td />
                <td />
                {pseudoInstructionColumn && <td />}
                {initialValues.slice(0, registerCount).map((value) => (
                  <td class="col-initial">{value}</td>
                ))}
                {memorySegments.map((segmentment, index) => (
                  <>
                    <td class="col-initial">
                      {initialValues[registerCount + index] ?? ""}
                    </td>
                    <td />
                  </>
                ))}
              </tr>
            )
          }
          {
            prefilledRows.map((row) => (
              <tr>
                <td class="col-filled">{row.pc}</td>
                <td class="col-filled">{row.instruction}</td>
                {pseudoInstructionColumn && (
                  <td class="col-filled">{row.pseudoInstruction ?? ""}</td>
                )}
                {row.values.slice(0, registerCount).map((value) => (
                  <td class="col-filled">{value}</td>
                ))}
                {memorySegments.map((segmentment, index) => (
                  <>
                    <td class="col-filled">
                      {row.values[registerCount + index] ?? ""}
                    </td>
                    <td />
                  </>
                ))}
              </tr>
            ))
          }
          {
            Array.from({ length: totalRows }).map(() => (
              <tr>
                <td>
                  <input type="text" />
                </td>
                <td>
                  <input type="text" />
                </td>
                {pseudoInstructionColumn && (
                  <td>
                    <input type="text" />
                  </td>
                )}
                {Array.from({ length: registerCount }).map(() => (
                  <td>
                    <input type="text" />
                  </td>
                ))}
                {memorySegments.map(() => (
                  <>
                    <td>
                      <input type="text" />
                    </td>
                    <td />
                  </>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="bottom-row">
      <p class="pdf-notice">{labels.pdfNotice}</p>
      <div class="btn-row">
        <button type="button" class="btn-add-row">{labels.addRow}</button>
        {correctRows.length > 0 && (
          <button type="button" class="btn-check">{labels.check}</button>
        )}
        <button type="button" class="btn-print" onclick="window.print()"
          >{labels.savePDF}</button
        >
      </div>
    </div>
  </form>
</div>

<script>
  document.querySelectorAll(".btn-add-row").forEach((button) => {
    button.addEventListener("click", () => {
      const tbody = button.closest("form")?.querySelector("tbody");
      const lastInputRow = Array.from(tbody?.querySelectorAll("tr") ?? [])
        .reverse()
        .find((row) => row.querySelector("input"));

      const newRow = lastInputRow?.cloneNode(true) as HTMLElement | undefined;
      newRow
        ?.querySelectorAll("input")
        .forEach((input) => ((input as HTMLInputElement).value = ""));
      newRow?.querySelectorAll("td").forEach((td) => {
        td.classList.remove("cell-correct", "cell-incorrect");
      });
      tbody?.appendChild(newRow!);
    });
  });

  function normalize(value: string): string {
    return value.trim().toLowerCase().replace(/\s+/g, " ");
  }

  function markCell(td: Element, correct: boolean) {
    td.classList.remove("cell-correct", "cell-incorrect");
    td.classList.add(correct ? "cell-correct" : "cell-incorrect");
  }

  document.querySelectorAll(".btn-check").forEach((button) => {
    button.addEventListener("click", () => {
      const form = button.closest("form") as HTMLFormElement;
      const correctRows = JSON.parse(form.dataset.correct ?? "[]") as {
        pc: string;
        instruction: string;
        values: string[];
      }[];
      const hasPseudo = form.dataset.pseudo === "1";
      const valueOffset = hasPseudo ? 3 : 2;
      const tbody = form.querySelector("tbody");

      const allInputRows = Array.from(tbody?.querySelectorAll("tr") ?? []).filter(
        (row) => row.querySelector("input")
      );

      const minRows = correctRows.length;
      const filledInputRows = allInputRows.filter(
        (row) => ((row.querySelector("input") as HTMLInputElement)?.value.trim() ?? "") !== ""
      );

      const emptyRows = allInputRows.filter((row) =>
        Array.from(row.querySelectorAll("input")).every(
          (input) => (input as HTMLInputElement).value.trim() === ""
        )
      );
      const emptyToKeep = Math.max(0, minRows - filledInputRows.length);
      emptyRows.slice(emptyToKeep).forEach((row) => row.remove());

      if (filledInputRows.length < minRows) return;

      // Clear previous marks
      allInputRows.forEach((row) => {
        row.querySelectorAll("td").forEach((td) => {
          td.classList.remove("cell-correct", "cell-incorrect");
        });
      });

      allInputRows.forEach((row, index) => {
        const correct = correctRows[index];
        if (!correct) return;

        const inputs = Array.from(row.querySelectorAll("input")) as HTMLInputElement[];

        const pcCorrect = normalize(inputs[0]?.value ?? "") === normalize(correct.pc);
        markCell(inputs[0]!.closest("td")!, pcCorrect);

        const instrCorrect = normalize(inputs[1]?.value ?? "") === normalize(correct.instruction);
        markCell(inputs[1]!.closest("td")!, instrCorrect);

        correct.values.forEach((expected, valIndex) => {
          if (expected === "") return;
          const input = inputs[valueOffset + valIndex];
          if (!input) return;
          markCell(input.closest("td")!, normalize(input.value) === normalize(expected));
        });
      });
    });
  });
</script>

<style>
  .exercise {
    font-family: Arial, sans-serif;
  }

  .code-wrapper h3 {
    margin-bottom: 0.5rem;
  }

  .assembly-code {
    background-color: var(--sl-color-gray-6, #f0f0f0);
    color: var(--sl-color-text, #000);
    padding: 12px;
    display: block;
    border-radius: 6px;
    white-space: pre-wrap;
    font-family: monospace;
    font-size: 14px;
    margin-bottom: 1.5rem;
  }

  .table-wrapper {
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .exec-table {
    border-collapse: collapse;
    border-spacing: 0;
    width: 100%;
    min-width: 700px;
  }

  .exec-table td,
  .exec-table th {
    border: 1px solid var(--sl-color-gray-4, #999);
    font-size: 14px;
    padding: 8px 6px;
    text-align: center;
    vertical-align: top;
    word-break: normal;
  }

  .exec-table.compact td,
  .exec-table.compact th {
    font-size: 11px;
    padding: 4px 3px;
  }

  .exec-table.compact input[type="text"] {
    font-size: 11px;
  }

  .col-before,
  .col-after {
    font-weight: bold;
    background-color: var(--sl-color-gray-6, #f5f5f5);
  }

  .col-header {
    font-weight: bold;
    text-align: center;
  }

  .col-alias {
    font-weight: bold;
    font-style: italic;
    color: var(--sl-color-gray-2, #555);
  }

  .col-initial {
    font-weight: bold;
    color: var(--sl-color-gray-2, #555);
  }

  .col-filled {
    font-weight: bold;
    font-family: monospace;
  }

  .exec-table input[type="text"] {
    width: 100%;
    border: none;
    text-align: center;
    background: transparent;
    font-family: monospace;
    font-size: 13px;
    color: inherit;
    padding: 2px;
    outline: none;
  }

  .exec-table input[type="text"]:focus {
    background-color: var(--sl-color-accent-low, #fff3e8);
    border-radius: 3px;
  }

  .bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .pdf-notice {
    font-size: 13px;
    color: var(--sl-color-gray-2, #555);
    margin: 0;
    flex: 1;
  }

  .btn-row {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
    align-items: stretch;
    margin-top: 0;
  }

  .btn-add-row,
  .btn-check,
  .btn-print {
    margin: 0;
    padding: 0 24px;
    border-radius: 6px;
    font-size: 15px;
    cursor: pointer;
    font-family: inherit;
  }

  .btn-add-row {
    background-color: transparent;
    color: var(--sl-color-accent, #e35c1f);
    border: 1.5px solid var(--sl-color-accent, #e35c1f);
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .btn-add-row:hover {
    background-color: var(--sl-color-accent, #e35c1f);
    color: white;
  }

  .btn-check {
    background-color: transparent;
    color: #16a34a;
    border: 1.5px solid #16a34a;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .btn-check:hover {
    background-color: #16a34a;
    color: white;
  }

  .btn-print {
    background-color: var(--sl-color-accent, #e35c1f);
    color: white;
    border: 1.5px solid var(--sl-color-accent, #e35c1f);
    transition: opacity 0.2s;
  }

  .btn-print:hover {
    opacity: 0.85;
  }

  .cell-correct {
    outline: 2px solid #16a34a;
    outline-offset: -2px;
  }

  .cell-incorrect {
    outline: 2px solid #dc2626;
    outline-offset: -2px;
  }

  @media print {
    @page {
      size: A2 landscape;
      margin: 1cm;
    }

    .bottom-row {
      display: none;
    }

    .exercise {
      font-size: 12px;
    }

    .exec-table td,
    .exec-table th {
      padding: 5px 4px;
    }
  }
</style>
